<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE generatorConfiguration
        PUBLIC "-//mybatis.org//DTD MyBatis Generator Configuration 1.0//EN"
        "http://mybatis.org/dtd/mybatis-generator-config_1_0.dtd">

<generatorConfiguration>
    <context id="DemoContext" targetRuntime="MyBatis3Simple">
        <commentGenerator>
            <property name="suppressAllComments" value="true"/>
        </commentGenerator>
        <jdbcConnection driverClass="com.mysql.cj.jdbc.Driver"
                        connectionURL="jdbc:mysql://localhost:3306/short_link_db"
                        userId="root"
                        password="123456"/>

        <javaModelGenerator targetPackage="com.example.shortlink.model" targetProject="src/main/java"/>
        <sqlMapGenerator targetPackage="mapper" targetProject="src/main/resources"/>
        <javaClientGenerator type="XMLMAPPER" targetPackage="com.example.shortlink.mapper" targetProject="src/main/java"/>

<!--        <table tableName="user" domainObjectName="User" schema="demo"/>-->
        <table tableName="short_link" domainObjectName="ShortLink" schema="short_link_db"/>
    </context>
</generatorConfiguration>
